# Copy to .env and fill in values before deploying
# Never commit .env to version control

# Database
POSTGRES_DB=railsignal
POSTGRES_USER=railsignal
POSTGRES_PASSWORD=changeme

# API
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Caddy (prod only)
DOMAIN=yourdomain.com

# Hetzner Object Storage (backups)
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_BUCKET=railsignal-backups
HETZNER_S3_ACCESS_KEY=
HETZNER_S3_SECRET_KEY=
